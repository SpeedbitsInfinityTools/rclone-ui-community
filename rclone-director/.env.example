# Rclone Director Configuration
# Copy this file to .env and customize for local development
#
# Usage:
#   cp .env.example .env
#   npm install
#   npm start

# ============================================
# UI Admin Login
# ============================================
# Password for logging into the web UI (used on first run only)
# After first login, password is hashed and stored in DATA_DIR/admin.json
ADMIN_PASSWORD=admin

# ============================================
# Data Storage
# ============================================
# Directory where config files are stored (servers, mounts, admin password)
# For local development, use a relative path like ./data
DATA_DIR=./data

# ============================================
# Rclone RCD Connection (default server)
# ============================================
# These settings configure the initial Rclone RCD server connection
# The Director proxies requests to this rclone instance
#
# Start rclone RCD with matching credentials:
#   rclone rcd --rc-addr=localhost:5572 --rc-user=admin --rc-pass=admin --rc-serve
#
# IMPORTANT: --rc-serve is required for file downloads to work!
#
RCLONE_DEFAULT_HOST=localhost
RCLONE_RCD_PORT=5572
RCLONE_DEFAULT_USER=admin
RCLONE_DEFAULT_PASS=admin
# Full URL (optional, overrides host/port). Use http:// for local, https:// for remote
# RCLONE_DEFAULT_URL=http://localhost:5572

# ============================================
# Server Settings (optional)
# ============================================
# PORT=5573
LOGS_DIR=./logs
